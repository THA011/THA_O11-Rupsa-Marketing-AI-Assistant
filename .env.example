# ============================================
# ENVIRONMENT CONFIGURATION - THA_O11
# ============================================

# Application
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tha_o11_dev
SQLALCHEMY_ECHO=true
DB_POOL_SIZE=10

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true

# JWT & Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# AI APIs
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Email Service
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@tha-o11.com

# AWS / Cloud Storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=tha-o11-assets

# Supabase (alternative to AWS)
SUPABASE_URL=
SUPABASE_KEY=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Sentry (Error Tracking)
SENTRY_DSN=

# Celery Task Queue
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Feature Flags
FEATURE_AI_GENERATION=true
FEATURE_ANALYTICS=true
FEATURE_RESEARCH_MODE=true
FEATURE_VIDEO_GENERATION=false

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_SAMPLE_RATE=1.0

# ============================================
# IMPORTANT: 
# - Never commit this file with real values
# - Copy to .env and fill with actual values
# - Add to .gitignore
# ============================================
