    "zustand": "^4.5.0",
    "react-hook-form": "^7.51.0",
    "recharts": "^2.12.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "@heroicons/react": "^2.1.0",
    "date-fns": "^3.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.2.0",
