  "description": "THA_O11 RAIP - configurable AI intelligence platform for SACCO marketing, statistics, research, and business intelligence",
  "private": true,
  "scripts": {
    "dev": "python -m http.server 3000 -d website",
    "build": "node -e \"console.log('Static website: no build step required')\"",
    "start": "python -m http.server 3000 -d website",
    "lint": "node -e \"console.log('Static website: no lint step configured')\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:migrate": "alembic upgrade head",
    "db:seed": "python scripts/seed_data.py"
  },
